{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/robot-agent/diagnosis-agent-plan.schema.json",
  "title": "Bounded Experiment Diagnosis Agent Plan",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "decision",
    "run_id",
    "summary",
    "steps",
    "clarification"
  ],
  "properties": {
    "schema_version": {"const": 1},
    "decision": {"enum": ["plan", "clarify", "refuse"]},
    "run_id": {
      "type": ["string", "null"],
      "pattern": "^[a-z0-9][a-z0-9_-]{2,63}$"
    },
    "summary": {"type": "string", "minLength": 1, "maxLength": 1000},
    "steps": {
      "type": "array",
      "maxItems": 5,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "step_id",
          "tool_name",
          "tool_version",
          "contract_sha256",
          "inputs",
          "reason",
          "expected_evidence"
        ],
        "properties": {
          "step_id": {"type": "integer", "minimum": 1, "maximum": 5},
          "tool_name": {
            "enum": [
              "list_experiment_runs",
              "inspect_experiment_run",
              "analyze_experiment_run",
              "retrieve_robotics_knowledge",
              "materialize_diagnosis_report"
            ]
          },
          "tool_version": {"const": "0.1.0"},
          "contract_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
          "inputs": {"type": "object", "maxProperties": 8},
          "reason": {"type": "string", "minLength": 1, "maxLength": 500},
          "expected_evidence": {
            "type": "array",
            "minItems": 1,
            "maxItems": 8,
            "items": {"type": "string", "minLength": 1, "maxLength": 200}
          }
        }
      }
    },
    "clarification": {"type": ["string", "null"], "maxLength": 1000}
  },
  "allOf": [
    {
      "if": {"properties": {"decision": {"const": "plan"}}},
      "then": {
        "properties": {
          "run_id": {"type": "string"},
          "steps": {
            "minItems": 5,
            "maxItems": 5,
            "prefixItems": [
              {"properties": {"step_id": {"const": 1}, "tool_name": {"const": "list_experiment_runs"}}},
              {"properties": {"step_id": {"const": 2}, "tool_name": {"const": "inspect_experiment_run"}}},
              {"properties": {"step_id": {"const": 3}, "tool_name": {"const": "analyze_experiment_run"}}},
              {"properties": {"step_id": {"const": 4}, "tool_name": {"const": "retrieve_robotics_knowledge"}}},
              {"properties": {"step_id": {"const": 5}, "tool_name": {"const": "materialize_diagnosis_report"}}}
            ]
          },
          "clarification": {"type": "null"}
        }
      }
    },
    {
      "if": {"properties": {"decision": {"enum": ["clarify", "refuse"]}}},
      "then": {
        "properties": {
          "run_id": {"type": "null"},
          "steps": {"maxItems": 0}
        }
      }
    },
    {
      "if": {"properties": {"decision": {"const": "clarify"}}},
      "then": {"properties": {"clarification": {"type": "string", "minLength": 1}}}
    },
    {
      "if": {"properties": {"decision": {"const": "refuse"}}},
      "then": {"properties": {"clarification": {"type": "null"}}}
    }
  ]
}
