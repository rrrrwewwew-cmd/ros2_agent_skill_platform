{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/robot-agent/skill-author-request.schema.json",
  "title": "Governed ROS 2 Skill Author Request",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "request_id", "name", "version", "description", "safety_level", "requires_human_approval", "allowed_dependencies", "acceptance_criteria"],
  "properties": {
    "schema_version": {"const": 1},
    "request_id": {"type": "string", "pattern": "^[A-Za-z0-9_.-]{3,96}$"},
    "name": {"type": "string", "pattern": "^[a-z][a-z0-9_]{2,63}$"},
    "version": {"type": "string", "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)$"},
    "description": {"type": "string", "minLength": 10, "maxLength": 1000},
    "safety_level": {"enum": ["read_only", "controlled"]},
    "requires_human_approval": {"type": "boolean"},
    "allowed_dependencies": {
      "type": "array",
      "minItems": 1,
      "maxItems": 6,
      "uniqueItems": true,
      "items": {
        "enum": [
          "check_robot_health",
          "query_semantic_target",
          "preview_safe_route",
          "navigate_to_approved_pose"
        ]
      }
    },
    "acceptance_criteria": {
      "type": "array",
      "minItems": 1,
      "maxItems": 12,
      "items": {"type": "string", "minLength": 3, "maxLength": 300}
    }
  },
  "allOf": [
    {
      "if": {"properties": {"safety_level": {"const": "controlled"}}},
      "then": {"properties": {"requires_human_approval": {"const": true}}}
    }
  ]
}
