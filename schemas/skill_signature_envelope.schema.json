{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/robot-agent/skill-signature-envelope.schema.json",
  "title": "Skill Signature Envelope",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "signature_algorithm",
    "artifact_hash_algorithm",
    "name",
    "version",
    "artifact_hash",
    "signer",
    "created_at_ns",
    "public_key_fingerprint",
    "signature"
  ],
  "properties": {
    "schema_version": {"const": 1},
    "signature_algorithm": {"const": "ed25519"},
    "artifact_hash_algorithm": {"const": "sha256-file-list-v1"},
    "name": {"type": "string", "pattern": "^[a-z][a-z0-9_]{2,63}$"},
    "version": {
      "type": "string",
      "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)$"
    },
    "artifact_hash": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "signer": {"type": "string", "minLength": 1},
    "created_at_ns": {"type": "integer", "minimum": 0},
    "public_key_fingerprint": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "signature": {
      "type": "string",
      "pattern": "^[A-Za-z0-9+/]+={0,2}$"
    }
  }
}
