{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/robot-agent/diagnosis-report-bundle.schema.json",
  "title": "Evidence-bound Robot Diagnosis Report Bundle",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "bundle_version",
    "run_id",
    "analysis_sha256",
    "knowledge_queries",
    "retrieval_evidence",
    "candidate_mechanisms",
    "limitations"
  ],
  "properties": {
    "schema_version": {"const": 1},
    "bundle_version": {"const": "0.1.0"},
    "run_id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9_-]{2,63}$"},
    "analysis_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "knowledge_queries": {
      "type": "array",
      "minItems": 1,
      "maxItems": 3,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["query", "distribution"],
        "properties": {
          "query": {"type": "string", "minLength": 3, "maxLength": 300},
          "distribution": {"enum": ["jazzy", "project1-v1", "project2-v1"]}
        }
      }
    },
    "retrieval_evidence": {
      "type": "array",
      "minItems": 1,
      "maxItems": 3,
      "items": {"type": "object"}
    },
    "candidate_mechanisms": {"type": "array", "items": {"type": "object"}},
    "limitations": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string"}
    }
  }
}
