{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/robot-agent/skill-author-result.schema.json",
  "title": "Governed Skill Author Pipeline Result",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "request_id", "status", "attempt_count", "candidate", "gates", "rag_citations", "registry_record", "approval_required", "error"],
  "properties": {
    "schema_version": {"const": 1},
    "request_id": {"type": "string", "minLength": 1},
    "status": {"enum": ["waiting_human_approval", "failed", "clarification_required", "refused"]},
    "attempt_count": {"type": "integer", "minimum": 0, "maximum": 3},
    "candidate": {
      "type": ["object", "null"]
    },
    "gates": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "status", "evidence"],
        "properties": {
          "name": {"enum": ["schema", "static", "build", "unit_test", "simulation"]},
          "status": {"enum": ["pass", "fail"]},
          "evidence": {"type": "object"}
        }
      }
    },
    "rag_citations": {"type": "array", "items": {"type": "object"}},
    "registry_record": {"type": ["object", "null"]},
    "approval_required": {"type": "boolean"},
    "error": {"type": ["string", "null"]}
  }
}
