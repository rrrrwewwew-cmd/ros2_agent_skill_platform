{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/robot-agent/skill-artifact-lock.schema.json",
  "title": "Skill Artifact Lock",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "name",
    "version",
    "hash_algorithm",
    "artifact_hash",
    "files"
  ],
  "properties": {
    "schema_version": {"const": 1},
    "name": {"type": "string", "pattern": "^[a-z][a-z0-9_]{2,63}$"},
    "version": {
      "type": "string",
      "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)$"
    },
    "hash_algorithm": {"const": "sha256-file-list-v1"},
    "artifact_hash": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "files": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9_.-]+(?:/[A-Za-z0-9_.-]+)*$"
      }
    }
  }
}
