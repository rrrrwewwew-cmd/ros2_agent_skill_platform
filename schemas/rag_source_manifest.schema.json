{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/rag_source_manifest.schema.json",
  "title": "Versioned RAG source manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "corpus_id",
    "corpus_version",
    "description",
    "chunking",
    "embedding",
    "retrieval_policy",
    "sources"
  ],
  "properties": {
    "schema_version": {"const": 1},
    "corpus_id": {"type": "string", "pattern": "^[a-z][a-z0-9_]{2,63}$"},
    "corpus_version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
    "description": {"type": "string", "minLength": 1, "maxLength": 500},
    "chunking": {
      "type": "object",
      "additionalProperties": false,
      "required": ["splitter", "max_terms", "overlap_terms"],
      "properties": {
        "splitter": {"const": "markdown_sections_v1"},
        "max_terms": {"type": "integer", "minimum": 20, "maximum": 1000},
        "overlap_terms": {"type": "integer", "minimum": 0, "maximum": 200}
      }
    },
    "embedding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["provider", "dimensions"],
      "properties": {
        "provider": {"enum": ["feature_hash_v1", "bge_m3_transformers_v1"]},
        "dimensions": {"type": "integer", "minimum": 64, "maximum": 2048},
        "model_id": {"type": "string", "minLength": 1, "maxLength": 200},
        "model_revision": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
        "normalize": {"type": "boolean"},
        "pooling": {"enum": ["cls"]},
        "max_length": {"type": "integer", "minimum": 32, "maximum": 8192},
        "batch_size": {"type": "integer", "minimum": 1, "maximum": 128},
        "vector_precision_decimals": {"type": "integer", "minimum": 4, "maximum": 12}
      },
      "allOf": [
        {
          "if": {"properties": {"provider": {"const": "bge_m3_transformers_v1"}}},
          "then": {
            "required": ["model_id", "model_revision", "normalize", "pooling", "max_length", "batch_size", "vector_precision_decimals"],
            "properties": {
              "dimensions": {"const": 1024},
              "normalize": {"const": true},
              "pooling": {"const": "cls"}
            }
          }
        }
      ]
    },
    "retrieval_policy": {"$ref": "#/$defs/retrieval_policy"},
    "sources": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "source_id",
          "version",
          "source_type",
          "title",
          "product",
          "distribution",
          "canonical_url",
          "license",
          "content_file",
          "content_sha256",
          "language",
          "tags"
        ],
        "properties": {
          "source_id": {"type": "string", "pattern": "^[a-z][a-z0-9_.-]{2,127}$"},
          "version": {"type": "string", "minLength": 1, "maxLength": 64},
          "source_type": {
            "enum": [
              "official_documentation",
              "project_interface",
              "skill_contract",
              "agent_contract",
              "evaluation_contract",
              "evaluation_distractor"
            ]
          },
          "title": {"type": "string", "minLength": 1, "maxLength": 200},
          "product": {"type": "string", "minLength": 1, "maxLength": 64},
          "distribution": {"type": "string", "minLength": 1, "maxLength": 32},
          "canonical_url": {"type": "string", "minLength": 1, "maxLength": 500},
          "license": {"type": "string", "minLength": 1, "maxLength": 200},
          "content_file": {
            "type": "string",
            "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$)).+"
          },
          "content_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
          "language": {"enum": ["en", "zh-CN", "bilingual"]},
          "tags": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": {"type": "string", "pattern": "^[a-z0-9_./-]+$"}
          },
          "retrieved_at": {"type": "string", "format": "date"}
        }
      }
    }
  },
  "$defs": {
    "retrieval_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["bm25_weight", "embedding_weight", "minimum_score", "minimum_embedding_score", "bm25_saturation"],
      "properties": {
        "bm25_weight": {"type": "number", "minimum": 0, "maximum": 1},
        "embedding_weight": {"type": "number", "minimum": 0, "maximum": 1},
        "minimum_score": {"type": "number", "minimum": 0, "maximum": 1},
        "minimum_embedding_score": {"type": "number", "minimum": 0, "maximum": 1},
        "bm25_saturation": {"type": "number", "exclusiveMinimum": 0},
        "require_embedding_gate": {"type": "boolean"},
        "reject_unknown_identifiers": {"type": "boolean"}
      }
    }
  }
}
