{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/robot-agent/prompt-evaluation-summary.schema.json",
  "title": "Prompt Evaluation Summary",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "evaluation_id",
    "provider",
    "model",
    "prompt_id",
    "prompt_version",
    "prompt_sha256",
    "status",
    "counts",
    "metrics",
    "runtime",
    "sample_results_file"
  ],
  "properties": {
    "schema_version": {"const": 1},
    "evaluation_id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9_.-]{3,96}$"
    },
    "provider": {"enum": ["xiaomi_mimo", "fake"]},
    "model": {"type": "string", "minLength": 1},
    "prompt_id": {"type": "string", "minLength": 1},
    "prompt_version": {"type": "string", "minLength": 1},
    "prompt_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "status": {"enum": ["complete", "partial"]},
    "counts": {
      "type": "object",
      "additionalProperties": false,
      "required": ["selected", "completed", "passed", "failed", "errors", "reused"],
      "properties": {
        "selected": {"type": "integer", "minimum": 1},
        "completed": {"type": "integer", "minimum": 0},
        "passed": {"type": "integer", "minimum": 0},
        "failed": {"type": "integer", "minimum": 0},
        "errors": {"type": "integer", "minimum": 0},
        "reused": {"type": "integer", "minimum": 0}
      }
    },
    "metrics": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_success_rate",
        "decision_accuracy",
        "skill_policy_accuracy",
        "injection_refusal_rate"
      ],
      "properties": {
        "schema_success_rate": {"type": ["number", "null"], "minimum": 0.0, "maximum": 1.0},
        "decision_accuracy": {"type": ["number", "null"], "minimum": 0.0, "maximum": 1.0},
        "skill_policy_accuracy": {"type": ["number", "null"], "minimum": 0.0, "maximum": 1.0},
        "injection_refusal_rate": {"type": ["number", "null"], "minimum": 0.0, "maximum": 1.0}
      }
    },
    "runtime": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "total_latency_ms",
        "average_latency_ms",
        "input_tokens",
        "output_tokens",
        "total_tokens"
      ],
      "properties": {
        "total_latency_ms": {"type": "number", "minimum": 0.0},
        "average_latency_ms": {"type": ["number", "null"], "minimum": 0.0},
        "input_tokens": {"type": "integer", "minimum": 0},
        "output_tokens": {"type": "integer", "minimum": 0},
        "total_tokens": {"type": "integer", "minimum": 0}
      }
    },
    "sample_results_file": {"type": "string", "minLength": 1}
  }
}
