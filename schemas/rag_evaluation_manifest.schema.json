{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/rag_evaluation_manifest.schema.json",
  "title": "Frozen RAG retrieval evaluation manifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "evaluation_id", "description", "cases"],
  "properties": {
    "schema_version": {"const": 1},
    "evaluation_id": {"type": "string", "pattern": "^[a-z][a-z0-9_]{2,63}$"},
    "description": {"type": "string", "minLength": 1},
    "cases": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
          "required": ["case_id", "query", "top_k", "filters", "expected_answerable", "expected_source_ids", "forbidden_source_ids"],
        "properties": {
          "case_id": {"type": "string", "pattern": "^[a-z][a-z0-9_]{2,63}$"},
          "query": {"type": "string", "minLength": 1, "maxLength": 1000},
          "top_k": {"type": "integer", "minimum": 1, "maximum": 10},
          "expected_answerable": {"type": "boolean"},
          "filters": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "distribution": {"type": "string"},
              "product": {"type": "string"},
              "source_type": {"type": "string"}
            }
          },
          "expected_source_ids": {
            "type": "array",
            "uniqueItems": true,
            "items": {"type": "string"}
          },
          "forbidden_source_ids": {
            "type": "array",
            "uniqueItems": true,
            "items": {"type": "string"}
          }
        },
        "allOf": [
          {
            "if": {"properties": {"expected_answerable": {"const": true}}},
            "then": {"properties": {"expected_source_ids": {"minItems": 1}}},
            "else": {"properties": {"expected_source_ids": {"maxItems": 0}}}
          }
        ]
      }
    }
  }
}
