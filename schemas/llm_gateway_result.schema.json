{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/robot-agent/llm-gateway-result.schema.json",
  "title": "Normalized MiMo Gateway Result",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "request_id",
    "provider",
    "model",
    "prompt_id",
    "prompt_version",
    "prompt_sha256",
    "request_sha256",
    "state",
    "plan",
    "error",
    "runtime"
  ],
  "properties": {
    "schema_version": {"const": 1},
    "request_id": {"type": "string", "minLength": 1},
    "provider": {"enum": ["xiaomi_mimo", "fake"]},
    "model": {"type": "string", "minLength": 1},
    "prompt_id": {"type": "string", "minLength": 1},
    "prompt_version": {"type": "string", "minLength": 1},
    "prompt_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "request_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "state": {"enum": ["succeeded", "failed"]},
    "plan": {"type": ["object", "null"]},
    "error": {
      "oneOf": [
        {"type": "null"},
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["code", "message"],
          "properties": {
            "code": {
              "enum": [
                "input_invalid",
                "prompt_mismatch",
                "provider_configuration",
                "provider_unavailable",
                "provider_response_invalid",
                "plan_schema_invalid"
              ]
            },
            "message": {"type": "string", "minLength": 1, "maxLength": 1000}
          }
        }
      ]
    },
    "runtime": {
      "type": "object",
      "additionalProperties": false,
      "required": ["latency_ms", "provider_request_id", "usage"],
      "properties": {
        "latency_ms": {"type": "number", "minimum": 0.0},
        "provider_request_id": {"type": ["string", "null"]},
        "usage": {
          "type": "object",
          "additionalProperties": false,
          "required": ["input_tokens", "output_tokens", "total_tokens"],
          "properties": {
            "input_tokens": {"type": ["integer", "null"], "minimum": 0},
            "output_tokens": {"type": ["integer", "null"], "minimum": 0},
            "total_tokens": {"type": ["integer", "null"], "minimum": 0}
          }
        }
      }
    }
  },
  "allOf": [
    {
      "if": {"properties": {"state": {"const": "succeeded"}}},
      "then": {
        "properties": {
          "plan": {"type": "object"},
          "error": {"type": "null"}
        }
      }
    },
    {
      "if": {"properties": {"state": {"const": "failed"}}},
      "then": {
        "properties": {
          "plan": {"type": "null"},
          "error": {"type": "object"}
        }
      }
    }
  ]
}
